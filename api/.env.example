# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # service role key — keep secret, bypasses RLS

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
META_WA_PHONE_NUMBER_ID=1234567890
META_WA_ACCESS_TOKEN=EAAxxxxxxxxx       # permanent system-user token
META_WA_BUSINESS_ACCOUNT_ID=9876543210
META_WA_VERIFY_TOKEN=choose_any_random_string_here

# ── WhatsApp Numbers ─────────────────────────────────────────────────────────
AI_WA_NUMBER=+18568782862               # Meta Cloud API number (AI agent sends from here)
SUPPORT_WA_NUMBER=+14254424167          # Human support fallback number

# ── Vapi (Voice AI) ───────────────────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key
VAPI_AGENT_ID=your_vapi_assistant_id
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...           # use sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Anthropic (AI agent + matching) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # powers AI agent (Pooja), therapist matching, RAG summaries

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@indiatherapist.com

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SECRET=choose_a_long_random_secret_min_32_chars

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.indiatherapist.com

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://www.indiatherapist.com,https://indiatherapist.com
