# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Environment variables (NEVER commit real secrets) ─────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
# Allow example files
!.env.example

# ── Build outputs ─────────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing / Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Vercel / Railway ──────────────────────────────────────────────────────────
.vercel/

# ── Supabase local ────────────────────────────────────────────────────────────
supabase/.temp/
supabase/.branches/
