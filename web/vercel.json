{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Frame-Options", "value": "DENY"},
        {"key": "X-Content-Type-Options", "value": "nosniff"}
      ]
    }
  ],
  "rewrites": [
    {"source": "/api/:path*", "destination": "https://api.indiatherapist.com/api/:path*"},
    {"source": "/webhooks/:path*", "destination": "https://api.indiatherapist.com/webhooks/:path*"}
  ]
}
